# Copy to `.env.local` for development. In Vercel: Project → Settings → Environment Variables
# (set for Production and Preview — redeploy after saving).

# --- Clerk (required for build — ClerkProvider runs on every route)
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workspace
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workspace
# Webhook: Clerk Dashboard → Webhooks → endpoint /api/webhooks/clerk (user.created, user.updated, user.deleted)
CLERK_WEBHOOK_SECRET=
# Used for invitation redirect URLs (defaults to VERCEL_URL or http://localhost:3000)
NEXT_PUBLIC_APP_URL=

# --- Supabase (Invitely + workspace Projects server actions)
# After creating a project: SQL Editor → run migrations in order from repo:
#   supabase/migrations/001_invitely.sql
#   supabase/migrations/002_projects.sql
#   supabase/migrations/003_fmv_entries.sql
#   supabase/migrations/004_app_users.sql
# URL: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Service role key — server-only, never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Access control (bootstrap admins on first sign-in; optional override)
# Defaults in code: g.tamutis@dayonestrategy.com, hello@gedas.info
# BOOTSTRAP_ADMIN_EMAILS=g.tamutis@dayonestrategy.com,hello@gedas.info

# --- Workspace industry news (RSS, server-side only)
# Comma-separated feed URLs. Optional label after | (defaults: BioSpace + Fierce Pharma).
# INDUSTRY_NEWS_FEED_URLS=https://www.biospace.com/all-news.rss|BioSpace,https://www.fiercepharma.com/rss/xml|Fierce Pharma
